-- Genel Oyunlar İçin Yükleme Ekranı Bariyeri
if not game:IsLoaded() then
    game.Loaded:Wait()
end
task.wait(4) -- Yeni sunucuya girildiğinde haritanın ve arayüzün oturması için 4 saniye güvenlik süresi

-- ==========================================
-- AYARLAR
-- ==========================================
local MESSAGE = "Azerbaycan sohbet oyunu yaz gir"
local MAX_SPAM_COUNT = 10 -- Her sunucuda atılacak mesaj sayısı
local DELAY = 0.1 -- Tüm oyunlarda chat ban yememek için en kararlı hız süresi

-- ==========================================
-- SERVİSLER
-- ==========================================
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer or Players.PlayerAdded:Wait()
local jumped = false
local currentSpamCount = 0

-- ==========================================
-- GENEL SERVER HOP MOTORU (267 KICK KORUMALI)
-- ==========================================
local function getNextServer()
    local success, result = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local raw = game:HttpGet(url)
        local servers = HttpService:JSONDecode(raw)
        for _, server in pairs(servers.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                return server.id
            end
        end
    end)
    return success and result or nil
end

local function serverHop()
    if jumped then return end
    jumped = true
    
    print("[SYSTEM] 15 Mesaj atıldı. Kick yememek için güvenli çıkış bekleniyor...")
    
    -- Hata Kodu 267 Almamak İçin Kritik Bekleme Süresi
    -- Sunucudan ayrılmadan önce oyunun verilerini kaydetmesi için 5 saniye frene basıyoruz
    task.wait(5) 
    
    local targetServerId = getNextServer()
    
    task.spawn(function()
        while true do
            pcall(function()
                if targetServerId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServerId, LocalPlayer)
                else
                    TeleportService:Teleport(game.PlaceId, LocalPlayer)
                end
            end)
            task.wait(5) -- Bağlantı kurulamazsa her 5 saniyede bir tekrar dener
        end
    end)
end

-- ==========================================
-- MESAJ GÖNDERME MOTORU
-- ==========================================
local function sendMessage(text)
    if jumped then return end
    
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local textChannel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if textChannel then
                textChannel:SendAsync(text)
                currentSpamCount = currentSpamCount + 1
            end
        else
            local remote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
            if remote then
                remote:FireServer(text, "All")
                currentSpamCount = currentSpamCount + 1
            end
        end
    end)
end

-- ==========================================
-- ANLIK GENEL SANSÜR / UYARI TAKİBİ
-- ==========================================
task.spawn(function()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui", 25)
    if playerGui then
        playerGui.DescendantAdded:Connect(function(descendant)
            if jumped then return end
            if descendant:IsA("TextLabel") then
                task.wait(0.05)
                local txt = string.lower(descendant.Text)
                -- Hangi oyun olursa olsun ekrana düşen filtre uyarılarını yakalar
                if string.find(txt, "beklemelisin") or string.find(txt, "before sending") or string.find(txt, "#") then
                    serverHop()
                end
            end
        end)
    end
end)

-- ==========================================
-- SPAM BAŞLATICI
-- ==========================================
task.spawn(function()
    while not jumped do
        if currentSpamCount >= MAX_SPAM_COUNT then
            serverHop()
            break
        end
        sendMessage(MESSAGE)
        task.wait(DELAY)
    end
end)
